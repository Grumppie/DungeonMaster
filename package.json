{
  "name": "dnd-agent-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:convex\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:convex": "convex dev",
    "dev:api": "python -m uvicorn server.app:app --reload --port 8000",
    "dev:legacy": "concurrently -k \"npm:dev:api\" \"npm:dev:client\"",
    "build": "vite build",
    "preview": "vite preview",
    "convex:deploy": "convex deploy",
    "corpus:ingest": "node scripts/ingest-corpus.mjs",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:headed": "playwright test --project=e2e --headed",
    "test:e2e:ui": "playwright test --project=e2e --ui",
    "test:e2e:bootstrap:host": "playwright test --project=bootstrap-host --headed",
    "test:e2e:bootstrap:guest": "playwright test --project=bootstrap-guest --headed"
  },
  "dependencies": {
    "@clerk/react": "^6.1.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@google/genai": "^1.46.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.7",
    "playwright": "^1.54.2",
    "vite": "^6.2.0"
  }
}
